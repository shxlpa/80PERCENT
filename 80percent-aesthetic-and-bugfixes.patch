+// Drift effect — uses CSS variable so it doesn't fight the :hover transform
+var drifts = Array.prototype.slice.call(document.querySelectorAll('.drift'));
+function applyDrift() {
+  // Disable drift on small screens (we already stack vertically there)
+  if (window.matchMedia('(max-width: 760px)').matches) {
+    drifts.forEach(function(el) { el.style.removeProperty('--drift'); });
+    return;
+  }
+  drifts.forEach(function(el) {
+    var rate = parseFloat(el.getAttribute('data-drift')) || 0;
+    var rect = el.getBoundingClientRect();
+    var offset = (rect.top - window.innerHeight / 2) * rate;
+    el.style.setProperty('--drift', offset + 'px');
   });
+}
