+// Reveal-on-scroll. On desktop the .block-photo scrolls internally, so the
+// IntersectionObserver root must be the block (not the window). Falls back to
+// the window automatically on mobile where the page itself scrolls.
+(function () {
+  var bc = document.querySelector('.block-photo');
+  var isDesktop = window.matchMedia('(min-width: 981px)').matches;
+  var opts = (isDesktop && bc) ? { root: bc, threshold: 0.1 } : { threshold: 0.1 };
+  var obs = new IntersectionObserver(function (entries) {
+    entries.forEach(function (e) { if (e.isIntersecting) e.target.classList.add('visible'); });
+  }, opts);
+  document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
+})();
